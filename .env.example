# Copy to .env and edit. Defaults assume Postgres + Redis from: docker compose up -d postgres redis
DATABASE_URL=postgres://foodapp:foodapp@127.0.0.1:5433/foodapp?sslmode=disable
REDIS_ADDR=127.0.0.1:6379
# If 8080 is already in use: PORT=8081
# Comma-separated origins for Next.js (default includes localhost:3000)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Comma-separated list of gzip URLs containing promo codes.
# Defaults use the 3 URLs provided to you (couponbase1/2/3).
# COUPON_BASE_URLS=https://.../couponbase1.gz,https://.../couponbase2.gz,https://.../couponbase3.gz
#
# Fixed discount percent applied when the promo code is valid.
# COUPON_DISCOUNT_PCT=15

# Optional cache file path for the parsed promo code set.
# If the file exists, the server loads it instead of re-downloading + re-scanning the gzip inputs.
# COUPON_CACHE_PATH=./data/coupon_cache.bin
